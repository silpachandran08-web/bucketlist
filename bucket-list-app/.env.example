# Upstash Redis — get these from console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# Shared password for you and your wife to log in
APP_PASSWORD=your-secret-password

# Secret key for signing auth cookies (generate a random 32+ char string)
AUTH_SECRET=your-super-secret-key-change-this
